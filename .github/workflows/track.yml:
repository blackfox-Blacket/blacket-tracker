name: Track Blacket Bazaar

on:
  schedule:
    # Runs every 10 minutes
    - cron: '*/10 * * * *'
  workflow_dispatch:  # Allows manual run

jobs:
  track:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      - name: Run tracker
        run: node tracker.js
        env:
          SHEET_URL: ${{ secrets.SHEET_URL }}
